# RAE Agentic Memory Configuration Template
# Copy this file to .env and fill in your keys

# Operational Mode
RAE_PROFILE=standard # options: standard, dev, lite, laptop
RAE_DB_MODE=migrate  # options: migrate, ignore, validate

# API Keys (Required for non-local LLM features)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROK_API_KEY=

# Local LLM (Ollama)
OLLAMA_API_URL=http://ollama-dev:11434

# Security
RAE_API_KEY=generate-a-secure-key-here
ENABLE_API_KEY_AUTH=false

# Persistence
POSTGRES_USER=rae
POSTGRES_PASSWORD=rae_password
POSTGRES_DB=rae
POSTGRES_HOST=rae-postgres

# Cache & Vectors
REDIS_URL=redis://rae-redis:6379/0
QDRANT_HOST=rae-qdrant
