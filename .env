# RAE Memory API - Optimized Local Configuration
POSTGRES_HOST=rae-postgres
POSTGRES_DB=rae
POSTGRES_USER=rae
POSTGRES_PASSWORD=rae_password

RAE_VECTOR_BACKEND=qdrant
QDRANT_HOST=rae-qdrant
QDRANT_PORT=6333
RAE_SIMILARITY_THRESHOLD=0.3

REDIS_URL=redis://rae-redis:6379/0
CELERY_BROKER_URL=redis://rae-redis:6379/1
CELERY_RESULT_BACKEND=redis://rae-redis:6379/2

# LLM & EMBEDDING
RAE_LLM_BACKEND=ollama
RAE_LLM_MODEL_DEFAULT=qwen2.5:3b
OLLAMA_API_URL=http://ollama-dev:11434

# ONNX Native Support
RAE_EMBEDDING_BACKEND=onnx
RAE_EMBEDDING_MODEL=models/nomic-embed-text-v1.5/model.onnx
RAE_RERANKER_MODEL=models/cross-encoder/model.onnx

# Security & Multi-tenancy
TENANCY_ENABLED=true
ALLOWED_ORIGINS=["*"]
ENABLE_API_KEY_AUTH=false

# Profiles
RAE_PROFILE=dev
RAE_DB_MODE=migrate
LOG_LEVEL=INFO
RAE_APP_LOG_LEVEL=INFO
PYTHONPATH=/app:/app/rae_core
