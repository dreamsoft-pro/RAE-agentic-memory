FROM python:3.11-slim

WORKDIR /app

# Install dependencies
RUN pip install --no-cache-dir \
    nicegui \
    httpx \
    structlog \
    pypdf \
    python-dotenv

# Copy the UI code
COPY ./rae_lite/ui/app.py ./main.py

# Expose port
EXPOSE 8080

# Environment variable for RAE API (using the container name in rae-network)
ENV RAE_API_URL=http://rae-api-dev:8000

CMD ["python", "main.py"]
