# Feniks Configuration Example
# Copy this file to .env and adjust the values

# --- Profile ---
FENIKS_PROFILE=dev  # dev or prod

# --- Paths ---
# FENIKS_FRONTEND_ROOT=/path/to/your/frontend
# FENIKS_OUTPUT_DIR=/path/to/output

# --- Qdrant Vector Database ---
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=code_chunks

# --- Embedding Model ---
EMBEDDING_MODEL=all-MiniLM-L6-v2

# --- RAE Integration (Iteration 5) ---
# Set to true to enable RAE integration
RAE_ENABLED=false

# RAE Base URL (e.g., http://localhost:8000 or https://rae.example.com)
# RAE_BASE_URL=http://localhost:8000

# RAE API Key or JWT token for authentication
# RAE_API_KEY=your_api_key_here

# Request timeout in seconds
RAE_TIMEOUT=30

# --- Enterprise Settings (Iteration 7) ---
# Observability
METRICS_ENABLED=true
# METRICS_EXPORT_PATH=metrics/feniks_metrics.json

# Security (Authentication & Authorization)
AUTH_ENABLED=false
# JWT_SECRET=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# Governance (Cost Control)
COST_CONTROL_ENABLED=false
DEFAULT_PROJECT_BUDGET=1000.0
