          },
          "editorMode": "code",
          "format": "table",
          "rawSql": "WITH RawData AS (\n    SELECT\n        timestamp,\n        value AS status,\n        LEAD(timestamp) OVER (ORDER BY timestamp) AS next_ts\n    FROM screenwatcher.collector_metriccontext\n    WHERE\n        key = 'status'\n        AND machine_id = '224bf64a-d590-486f-8aee-9e4b5cedc198'\n        AND $__timeFilter(timestamp)\n)\nSELECT\n    timestamp AS \"time\",\n    TIMESTAMPDIFF(SECOND, timestamp, next_ts) AS \"Czas Trwania (s)\"\nFROM RawData\nWHERE\n    status = 'STOPPED'\n    AND TIMESTAMPDIFF(SECOND, timestamp, next_ts) > 0\n    AND TIMESTAMPDIFF(SECOND, timestamp, next_ts) <= 30\nORDER BY timestamp ASC",
