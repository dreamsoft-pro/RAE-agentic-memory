          },
          "editorMode": "code",
          "format": "table",
          "rawSql": "WITH RawData AS (\n    SELECT\n        timestamp,\n        CASE WHEN value > 0 THEN \"RUNNING\" ELSE \"STOPPED\" END AS status,\n        LEAD(timestamp) OVER (ORDER BY timestamp) AS next_ts\n    FROM screenwatcher.collector_metricreading\n    WHERE\n        name = \"speed_m2h\"\n        AND machine_id = \"224bf64a-d590-486f-8aee-9e4b5cedc198\"\n        AND $__timeFilter(timestamp)\n)\nSELECT\n    timestamp AS \"time\",\n    TIMESTAMPDIFF(SECOND, timestamp, next_ts) AS \"Czas Trwania (s)\"\nFROM RawData\nWHERE\n    status = \"STOPPED\"\n    AND TIMESTAMPDIFF(SECOND, timestamp, next_ts) > 15\n    AND TIMESTAMPDIFF(SECOND, timestamp, next_ts) <= 300\nORDER BY timestamp ASC",
          "refId": "A",
