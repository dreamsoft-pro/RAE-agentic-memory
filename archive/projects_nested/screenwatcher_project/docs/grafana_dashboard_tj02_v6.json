            "uid": "${DS_MYSQL}"
          },
          "editorMode": "code",
          "format": "time_series",
          "rawSql": "WITH StanMaszyny AS (\n  SELECT\n    timestamp,\n    GROUP_CONCAT(value ORDER BY name) as signature\n  FROM screenwatcher.collector_metricreading\n  WHERE\n    machine_id = '224bf64a-d590-486f-8aee-9e4b5cedc198'\n    AND $__timeFilter(timestamp)\n  GROUP BY timestamp\n),\nAnaliza AS (\n  SELECT\n    timestamp,\n    signature,\n    LAG(signature) OVER (ORDER BY timestamp) as prev_signature,\n    LAG(timestamp) OVER (ORDER BY timestamp) as prev_ts\n  FROM StanMaszyny\n)\nSELECT\n  timestamp as \"time\",\n  CASE\n    -- Bezpiecznik: Jeśli dziura w danych > 60s -> OFFLINE (0)\n    WHEN TIMESTAMPDIFF(SECOND, prev_ts, timestamp) > 60 THEN 0\n    -- Jeśli dane ciągłe i zmiana stanu -> PRACA (1.0)\n    WHEN signature != prev_signature THEN 1.0\n    -- Jeśli dane ciągłe i brak zmiany -> IDLE (0.8)\n    ELSE 0.8\n  END as \"Status\"\nFROM Analiza\nORDER BY timestamp",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          },
          "table": "collector_metriccontext"
        }
      ],
