      "targets": [
        {
          "dataset": "screenwatcher",
          "datasource": {
            "type": "mysql",
            "uid": "${DS_MYSQL}"
          },
          "editorMode": "code",
          "format": "time_series",
          "rawSql": "\nSELECT\n  timestamp AS time,\n  TIMESTAMPDIFF(SECOND, (timestamp + INTERVAL (time_consuming_h * 3600) SECOND), next_job_start_time) / 3600 AS \"Przerwa (h)\"\nFROM (\n  SELECT\n    timestamp,\n    time_consuming_h,\n    LEAD(timestamp) OVER (PARTITION BY machine_id ORDER BY timestamp) AS next_job_start_time,\n    machine_id\n  FROM screenwatcher.oee_productionjob\n  WHERE\n    machine_id = '224bf64a-d590-486f-8aee-9e4b5cedc198'\n    AND time_consuming_h > 0\n) AS sub\nWHERE\n  TIMESTAMPDIFF(SECOND, (timestamp + INTERVAL (time_consuming_h * 3600) SECOND), next_job_start_time) > 0\n  AND $__timeFilter(timestamp)\nORDER BY timestamp ASC\n",
          "refId": "A",
          "legendFormat": "Przerwa (h)"
        }
