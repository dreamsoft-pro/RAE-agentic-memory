          "editorMode": "code",
          "format": "time_series",
          "rawSql": "\nSELECT\n  $__timeGroup(timestamp, '$__interval') AS time,\n  AVG(print_area / time_consuming_h) AS \"Produkcja (m2/h)\"\nFROM screenwatcher.oee_productionjob\nWHERE\n  machine_id = '224bf64a-d590-486f-8aee-9e4b5cedc198'\n  AND time_consuming_h > 0\n  AND (print_area / time_consuming_h) <= 400\n  AND $__timeFilter(timestamp)\nGROUP BY 1\nORDER BY 1\n",
