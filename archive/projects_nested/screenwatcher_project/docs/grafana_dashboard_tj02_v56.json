      "targets": [
        {
          "dataset": "screenwatcher",
          "datasource": {
            "type": "mysql",
            "uid": "${DS_MYSQL}"
          },
          "editorMode": "code",
          "format": "time_series",
          "interval": "10s",
          "rawSql": "SELECT\n  $__timeGroup(sub.time_bucket, '$__interval', 0) AS time,\n  MAX(CASE WHEN sub.metric_count = 0 THEN 1 ELSE NULL END) AS \"Brak Danych (t\u0142o)\"\nFROM (\n  SELECT\n    $__timeGroup(cmr.timestamp, '$__interval', 0) AS time_bucket,\n    COUNT(cmr.value) AS metric_count\n  FROM screenwatcher.collector_metricreading cmr\n  WHERE\n    cmr.machine_id = '224bf64a-d590-486f-8aee-9e4b5cedc198'\n    AND cmr.name = 'speed_m2h'\n    AND $__timeFilter(cmr.timestamp)\n  GROUP BY 1\n) AS sub\nGROUP BY 1\nORDER BY 1",
          "refId": "A",
          "legendFormat": "Brak Danych (t\u0142o)"
        },
        {
          "dataset": "screenwatcher",
          "datasource": {
            "type": "mysql",
            "uid": "${DS_MYSQL}"
          },
          "editorMode": "code",
          "format": "time_series",
          "interval": "10s",
          "rawSql": "WITH CombinedMachineData AS (\n  SELECT\n    mr.timestamp,\n    mr.machine_id,\n    mr.value AS speed_m2h,\n    mc.value AS current_idle_state_key,\n    LAG(mc.value, 1) OVER (PARTITION BY mc.machine_id ORDER BY mr.timestamp) AS prev_idle_state_key\n  FROM screenwatcher.collector_metricreading mr\n  LEFT JOIN screenwatcher.collector_metriccontext mc ON\n    mr.timestamp = mc.timestamp AND mr.machine_id = mc.machine_id AND mc.key = 'idle_state_key'\n  WHERE\n    mr.machine_id = '224bf64a-d590-486f-8aee-9e4b5cedc198'\n    AND mr.name = 'speed_m2h'\n    AND $__timeFilter(mr.timestamp)\n)\nSELECT\n  $__timeGroup(cmd.timestamp, '$__interval', 0) AS time,\n  MAX(CASE\n    WHEN cmd.speed_m2h IS NULL THEN 0.0 -- Data Gap\n    WHEN cmd.current_idle_state_key IS NOT NULL AND cmd.current_idle_state_key <=> cmd.prev_idle_state_key THEN 0.8 -- Machine Idle\n    WHEN cmd.speed_m2h > 10 THEN 1.0 -- Working\n    ELSE 0.8 -- Default to idle/stopped if not working or data gap\n  END) AS \"Status\"\nFROM CombinedMachineData cmd\nGROUP BY 1\nORDER BY 1",
          "refId": "B",
          "legendFormat": "{{metric}}"
        },
        {
          "dataset": "screenwatcher",
          "datasource": {
            "type": "mysql",
            "uid": "${DS_MYSQL}"
          },
          "editorMode": "code",
          "format": "time_series",
          "interval": "10s",
          "rawSql": "WITH CombinedMachineData AS (\n  SELECT\n    mr.timestamp,\n    mr.machine_id,\n    mr.value AS speed_m2h,\n    mc.value AS current_idle_state_key,\n    LAG(mc.value, 1) OVER (PARTITION BY mc.machine_id ORDER BY mr.timestamp) AS prev_idle_state_key\n  FROM screenwatcher.collector_metricreading mr\n  LEFT JOIN screenwatcher.collector_metriccontext mc ON\n    mr.timestamp = mc.timestamp AND mr.machine_id = mc.machine_id AND mc.key = 'idle_state_key'\n  WHERE\n    mr.machine_id = '224bf64a-d590-486f-8aee-9e4b5cedc198'\n    AND mr.name = 'speed_m2h'\n    AND $__timeFilter(mr.timestamp)\n)\nSELECT\n  $__timeGroup(cmd.timestamp, '$__interval', 0) AS time,\n  CASE WHEN cmd.current_idle_state_key IS NOT NULL AND cmd.current_idle_state_key <=> cmd.prev_idle_state_key THEN 0 ELSE cmd.speed_m2h END AS \"Pr\u0119dko\u015b\u0107 (m2/h)\"\nFROM CombinedMachineData cmd\nWHERE\n  cmd.speed_m2h <= 450 \nORDER BY time",
          "refId": "C",
          "legendFormat": "Pr\u0119dko\u015b\u0107 (m2/h)"
        },
        {
          "dataset": "screenwatcher",
          "datasource": {
            "type": "mysql",
            "uid": "${DS_MYSQL}"
          },
          "editorMode": "code",
          "format": "time_series",
          "interval": "10s",
          "rawSql": "WITH CombinedMachineData AS (\n  SELECT\n    mr.timestamp,\n    mr.machine_id,\n    mr.value AS speed_m2h,\n    mc.value AS current_idle_state_key,\n    LAG(mc.value, 1) OVER (PARTITION BY mc.machine_id ORDER BY mr.timestamp) AS prev_idle_state_key\n  FROM screenwatcher.collector_metricreading mr\n  LEFT JOIN screenwatcher.collector_metriccontext mc ON\n    mr.timestamp = mc.timestamp AND mr.machine_id = mc.machine_id AND mc.key = 'idle_state_key'\n  WHERE\n    mr.machine_id = '224bf64a-d590-486f-8aee-9e4b5cedc198'\n    AND mr.name = 'speed_m2h'\n    AND $__timeFilter(mr.timestamp)\n),\nMachineStatus AS (\n    SELECT\n        cmd.timestamp,\n        cmd.machine_id,\n        CASE\n            WHEN cmd.speed_m2h > 10 THEN 'RUNNING'\n            WHEN cmd.current_idle_state_key IS NOT NULL AND cmd.current_idle_state_key <=> cmd.prev_idle_state_key THEN 'STOPPED'\n            ELSE 'STOPPED'\n        END AS status\n    FROM CombinedMachineData cmd\n),\nCalculatedDurations AS (\n    SELECT\n        ms.timestamp,\n        ms.status,\n        TIMESTAMPDIFF(SECOND, ms.timestamp, LEAD(ms.timestamp) OVER (PARTITION BY ms.machine_id ORDER BY ms.timestamp)) AS duration_s\n    FROM MachineStatus ms\n)\nSELECT\n    cd.timestamp AS \"time\",\n    cd.duration_s AS \"Mikroprzestoje (15s-5min)\"\nFROM CalculatedDurations cd\nWHERE\n    cd.status = \"STOPPED\"\n    AND cd.duration_s >= 15\n    AND cd.duration_s <= 300\nORDER BY cd.timestamp ASC",
          "refId": "D",
          "legendFormat": "Mikroprzestoje (15s-5min)"
        },
        {
          "dataset": "screenwatcher",
          "datasource": {
            "type": "mysql",
            "uid": "${DS_MYSQL}"
          },
          "editorMode": "code",
          "format": "time_series",
          "interval": "10s",
          "rawSql": "WITH CombinedMachineData AS (\n  SELECT\n    mr.timestamp,\n    mr.machine_id,\n    mr.value AS speed_m2h,\n    mc.value AS current_idle_state_key,\n    LAG(mc.value, 1) OVER (PARTITION BY mc.machine_id ORDER BY mr.timestamp) AS prev_idle_state_key\n  FROM screenwatcher.collector_metricreading mr\n  LEFT JOIN screenwatcher.collector_metriccontext mc ON\n    mr.timestamp = mc.timestamp AND mr.machine_id = mc.machine_id AND mc.key = 'idle_state_key'\n  WHERE\n    mr.machine_id = '224bf64a-d590-486f-8aee-9e4b5cedc198'\n    AND mr.name = 'speed_m2h'\n    AND $__timeFilter(mr.timestamp)\n),\nMachineStatus AS (\n    SELECT\n        cmd.timestamp,\n        cmd.machine_id,\n        CASE\n            WHEN cmd.speed_m2h > 10 THEN 'RUNNING'\n            WHEN cmd.current_idle_state_key IS NOT NULL AND cmd.current_idle_state_key <=> cmd.prev_idle_state_key THEN 'STOPPED'\n            ELSE 'STOPPED'\n        END AS status\n    FROM CombinedMachineData cmd\n),\nCalculatedDurations AS (\n    SELECT\n        ms.timestamp,\n        ms.status,\n        TIMESTAMPDIFF(SECOND, ms.timestamp, LEAD(ms.timestamp) OVER (PARTITION BY ms.machine_id ORDER BY ms.timestamp)) AS duration_s\n    FROM MachineStatus ms\n)\nSELECT\n    cd.timestamp AS \"time\",\n    cd.duration_s AS \"D\u0142u\u017csze przestoje (>5min)\"\nFROM CalculatedDurations cd\nWHERE\n    cd.status = \"STOPPED\"\n    AND cd.duration_s > 300\nORDER BY cd.timestamp ASC",
          "refId": "E",
          "legendFormat": "D\u0142u\u017csze przestoje (>5min)"
        }
      ],
      "title": "Wydajno\u015b\u0107, Status i Przestoje",
