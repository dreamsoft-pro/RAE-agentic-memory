# Domyślnie traktuj pliki jako tekst i normalizuj do LF w repo
* text=auto eol=lf

# Pliki źródłowe – twardo LF
*.py   text eol=lf
*.pyi  text eol=lf
*.txt  text eol=lf
*.md   text eol=lf
*.json text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.ini  text eol=lf
*.cfg  text eol=lf
*.html text eol=lf
*.css  text eol=lf
*.js   text eol=lf

# Skrypty systemowe
*.sh   text eol=lf
*.ps1  text eol=crlf
*.bat  text eol=crlf
*.cmd  text eol=crlf

# Binaria – nigdy nie ruszaj końcówek
*.png  -text
*.jpg  -text
*.jpeg -text
*.gif  -text
*.pdf  -text
*.ico  -text
*.ttf  -text
*.woff -text
*.woff2 -text
